# Container identity and image
CONTAINER_NAME=windrose
HOSTNAME=localhost
IMAGE_REPOSITORY=ghcr.io/uberdudepl/windrose-dedicated-server-docker
IMAGE_TAG=v1.1.13

# Host permissions
PUID=1000
PGID=1000

# Steam / game
STEAM_LOGIN=anonymous
STEAM_PASS=
WINDROSE_APP_ID=4129620
UPDATE_ON_START=true
GENERATE_SETTINGS=true

# ServerDescription.json patching
INVITE_CODE=
SERVER_NAME=My Windrose Server
SERVER_NOTE=Friendly co-op server
SERVER_PASSWORD=
MAX_PLAYERS=4
P2P_PROXY_ADDRESS=127.0.0.1

# Notifications
NOTIFY_PROVIDER=auto
DISCORD_WEBHOOK_URL=
GOTIFY_URL=
GOTIFY_TOKEN=
GOTIFY_PRIORITY=5
NOTIFY_DEDUPE_WINDOW=90
NOTIFY_TAIL_LINES=0
NOTIFY_DEBUG=false

# Backups
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7

# Networking
PORT=7777
QUERYPORT=7778
MULTIHOME=0.0.0.0
